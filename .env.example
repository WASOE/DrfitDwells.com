# ===========================================
# Drift & Dwells — Environment Variables
# ===========================================
# Copy to .env and fill in your values.

# --- Server ---
PORT=5000
NODE_ENV=development
# Number of reverse-proxy hops for client IP (req.ip). Default in code is 1 if unset. Verify against real X-Forwarded-For in staging/prod.
# TRUST_PROXY=1

# --- Multi-unit inventory (A-Frame pooled booking) ---
# Production: set both explicitly (multi-unit is OFF in prod when MULTI_UNIT_ENABLED is unset).
# MULTI_UNIT_ENABLED=true
# MULTI_UNIT_TYPES=a-frame
# Local dev: defaults match a-frame when NODE_ENV is not production; override if needed.

# --- MongoDB ---
MONGODB_URI=mongodb://localhost:27017/drift-dwells-booking

# --- Admin Credentials (REQUIRED in production) ---
ADMIN_USER=admin
ADMIN_PASS=change-me-in-production
ADMIN_JWT_SECRET=change-me-random-secret-64-chars

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_CURRENCY=eur

# --- Email (SMTP) ---
# Format: smtps://user:pass@smtp.provider.com
SMTP_URL=
# Optional explicit SMTP transport (overrides SMTP_URL when SMTP_HOST is set)
# SMTP_HOST=127.0.0.1
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_TLS_SERVERNAME=
# Require hard-failure behavior if delivery is unavailable
# EMAIL_DELIVERY_REQUIRED=1
EMAIL_FROM=noreply@driftanddwells.com
EMAIL_TO_INTERNAL=ops@driftanddwells.com
# Booking email HTML: logo (optional). For admin preview + mail clients, use a public HTTPS URL or set fallbacks below.
# EMAIL_BRAND_LOGO_URL=https://driftdwells.com/uploads/Logo/DRIFTS-01.png
# EMAIL_BRAND_LOGO_PATH=/uploads/Logo/DRIFTS-01.png
# When APP_URL is localhost, logo path is joined to this origin (default https://driftdwells.com) so previews are not broken.
# EMAIL_LOGO_FALLBACK_ORIGIN=https://driftdwells.com
# Override public asset host for logo path only (CDN or apex vs www):
# EMAIL_PUBLIC_ASSET_ORIGIN=https://driftdwells.com
# EMAIL_BRAND_LOGO_DISABLE=1

# --- CORS (comma-separated allowed origins) ---
# In production, set to your domain(s)
CORS_ORIGINS=https://driftanddwells.com,https://www.driftanddwells.com

# --- Public social (optional overrides; defaults match production profiles) ---
# INSTAGRAM_URL=https://www.instagram.com/driftdwells/
# FACEBOOK_URL=https://www.facebook.com/profile.php?id=61569960933269
# VITE_INSTAGRAM_URL=
# VITE_FACEBOOK_URL=

# --- Client (Vite — prefix with VITE_) ---
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Google Tag Manager (loads after consent; configure GA4 + Google Ads tags inside GTM)
# In GTM: add Conversion Linker (All Pages after consent) + your Ads/GA4 conversion tags.
VITE_GTM_ID=GTM-XXXXXXX
# Optional: server URL to POST JSON web-vitals (LCP, CLS, INP) for internal RUM
# VITE_WEB_VITALS_ENDPOINT=https://api.example.com/internal/web-vitals
# Optional: Google Ads ID for gtag.js conversion linker when not relying on GTM alone (loads with ads consent)
# VITE_GOOGLE_ADS_ID=AW-XXXXXXXXX
# Meta Pixel (loads after consent; Purchase also sent via server CAPI for dedup)
VITE_META_PIXEL_ID=

# --- Paid ads / booking attribution (server) ---
# Meta Conversions API — same Pixel ID as VITE_META_PIXEL_ID; system user token with ads_management
META_PIXEL_ID=
META_CAPI_ACCESS_TOKEN=
# When true/1, Purchase CAPI includes hashed ph/fn/ln, fbp/fbc, event_source_url (from booking.metaClientContext)
META_CAPI_PURCHASE_ENRICHED=0
# Optional: comma-separated allowed origins for metaClientContext.eventSourceUrl (defaults to CORS_ORIGINS, else localhost dev)
# Use when preview/staging host is not in CORS_ORIGINS
# META_CLIENT_CONTEXT_ALLOWED_ORIGINS=https://staging.example.com,https://www.driftanddwells.com
# Optional Graph API version for CAPI (default v21.0)
# META_CAPI_GRAPH_VERSION=v21.0
# Optional: server CAPI Test Events only (Events Manager test code). Omit in production.
# META_TEST_EVENT_CODE=TEST98434
# GA4 purchase value currency sent to tags + CAPI
BOOKING_TRACKING_CURRENCY=EUR
# If set to 1, guest bookings without Stripe PaymentIntent are stored as confirmed (dev / invoice flow only)
# BOOKING_CONFIRM_WITHOUT_STRIPE=1
