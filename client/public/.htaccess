RewriteEngine On

# Keep app shell + service worker revalidation strict to avoid stale bundles.
<IfModule mod_headers.c>
  <FilesMatch "\.(js|css|woff2|png|jpg|jpeg|webp|avif|svg)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  <FilesMatch "^(index\.html|sw\.js)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </FilesMatch>
</IfModule>

# Canonicalize legacy login path before SPA fallback.
RewriteRule ^admin/login/?$ /login [R=302,L]

# Do not route API calls to the React app
RewriteCond %{REQUEST_URI} !^/api/ [NC]

# Serve real files and folders normally
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# Only rewrite extensionless app routes, not missing .js/.css/.png/.pdf files
RewriteCond %{REQUEST_URI} !\.[a-zA-Z0-9]{2,8}$

RewriteRule ^ /index.html [L]
