{
  "name": "drift-dwells-booking-client",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "validate:media": "node ./scripts/validate-media-assets.mjs",
    "validate:calendaruxinteractions": "node ./scripts/validate-calendar-ux-interactions.mjs",
    "build": "npm run validate:media && vite build && node ./scripts/prerender-routes.cjs",
    "lint": "eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview --host",
    "check:i18n": "node ./scripts/check-i18n.mjs"
  },
  "dependencies": {
    "@stripe/react-stripe-js": "^5.6.1",
    "@stripe/stripe-js": "^8.9.0",
    "axios": "^1.6.2",
    "date-fns": "^2.30.0",
    "date-fns-tz": "^2.0.1",
    "framer-motion": "^12.23.24",
    "i18next": "^23.11.5",
    "jspdf": "^2.5.1",
    "lucide-react": "^0.554.0",
    "react": "^18.2.0",
    "react-datepicker": "^4.25.0",
    "react-day-picker": "^9.11.2",
    "react-dom": "^18.2.0",
    "react-helmet-async": "^1.3.0",
    "react-i18next": "^15.0.0",
    "react-icons": "^5.5.0",
    "react-router-dom": "^6.20.1"
  },
  "devDependencies": {
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15",
    "@vitejs/plugin-react": "^4.1.1",
    "autoprefixer": "^10.4.16",
    "eslint": "^8.53.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.4",
    "postcss": "^8.4.32",
    "puppeteer-core": "^24.39.0",
    "tailwindcss": "^3.3.6",
    "vite": "^5.0.0",
    "vite-plugin-prerender": "^1.0.8",
    "vite-plugin-prerender-esm-fix": "^1.0.8"
  }
}
